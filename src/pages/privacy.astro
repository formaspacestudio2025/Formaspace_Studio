---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
---

<Layout title="Privacy Policy | Formaspace Studio" description="Formaspace Studio privacy policy — how we collect, use, and protect your personal information.">
  <Breadcrumb path={[{ label: 'Privacy Policy' }]} />
  <main class="max-w-3xl mx-auto px-6 py-24">
    <h1 class="font-display text-4xl md:text-5xl text-text-primary mb-8">Privacy Policy</h1>
    <div class="text-text-secondary space-y-6 leading-relaxed">
      <p>Last updated: June 2026</p>
      <h2 class="text-text-primary text-xl font-semibold mt-8">Information We Collect</h2>
      <p>When you submit a contact form on our website, we collect your name, email address, company name, phone number, and message. This information is used solely to respond to your enquiry.</p>
      <h2 class="text-text-primary text-xl font-semibold mt-8">How We Use Your Information</h2>
      <p>We use the information you provide to respond to your enquiries, provide our services, and improve our website. We do not sell, rent, or share your personal information with third parties except as required by law.</p>
      <h2 class="text-text-primary text-xl font-semibold mt-8">Data Storage</h2>
      <p>Contact form submissions are transmitted securely and stored temporarily for processing. We retain enquiry data for a maximum of 12 months after the last contact.</p>
      <h2 class="text-text-primary text-xl font-semibold mt-8">Your Rights</h2>
      <p>You have the right to request access to, correction of, or deletion of your personal data. To exercise these rights, contact us at info@formaspacestudio.com.</p>
      <h2 class="text-text-primary text-xl font-semibold mt-8">Cookies</h2>
      <p>This website does not use cookies or any tracking technologies beyond standard server logs.</p>
      <h2 class="text-text-primary text-xl font-semibold mt-8">Contact</h2>
      <p>For questions about this privacy policy, contact us at info@formaspacestudio.com.</p>
    </div>
  </main>
</Layout>