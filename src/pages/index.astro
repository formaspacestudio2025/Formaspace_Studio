  svg.appendChild(t2);
  const tooltip = document.createElementNS('http://www.w3.org/2000/svg','g');
  tooltip.style.opacity = '0'; tooltip.style.transition = 'opacity 0.2s'; tooltip.style.pointerEvents = 'none';
  const tBg = document.createElementNS('http://www.w3.org/2000/svg','rect');
  tBg.setAttribute('x','220'); tBg.setAttribute('y','100'); tBg.setAttribute('width','70'); tBg.setAttribute('height','36');
  tBg.setAttribute('fill','#111318'); tBg.setAttribute('rx','2'); tBg.setAttribute('stroke','#F5A623'); tBg.setAttribute('stroke-width','0.5');
