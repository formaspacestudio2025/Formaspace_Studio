<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Formaspace | Digital Engineering, BIM &amp; Project Controls</title>
<meta name="description" content="Formaspace — Project Management Consultancy &amp; Digital Engineering firm. Digital Engineering, BIM, Project Controls and Construction Intelligence.">
<meta property="og:title" content="Formaspace | Digital Engineering, BIM &amp; Project Controls">
<meta property="og:description" content="Project Management Consultancy &amp; Digital Engineering firm at the intersection of construction intelligence, BIM, and data-driven project delivery.">
<meta property="og:image" content="/logos/FSS App branding without background.png">
<meta property="og:type" content="website">
<meta name="twitter:card" content="summary_large_image">
<link rel="icon" type="image/png" href="/logos/FSS logo.png">
<link rel="apple-touch-icon" href="/logos/FSS App branding without background.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=IBM+Plex+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --black: #0A0C10;
  --black2: #0d1018;
  --surface: #111318;
  --surface2: #161b24;
  --surface3: #1a2030;
  --amber: #F5A623;
  --amber2: #ffb84d;
  --amber-dim: rgba(245,166,35,0.15);
  --blue: #4FC3F7;
  --blue-dim: rgba(79,195,247,0.12);
  --white: #f0ece4;
  --white2: #c8c4bc;
  --white3: #7a7870;
  --mono: 'IBM Plex Mono', monospace;
  --serif: 'DM Serif Display', serif;
  --sans: 'DM Sans', sans-serif;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(245,166,35,0.3);
  --glow: rgba(245,166,35,0.04);
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  background: var(--black);
  color: var(--white);
  font-family: var(--sans);
  overflow-x: hidden;
}
body:not(.touch) { cursor: none; }
::selection { background: rgba(245,166,35,0.3); color: #fff; }
img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }
button { border: none; background: none; font: inherit; color: inherit; }

/* NOISE OVERLAY */
#grain {
  position: fixed; inset: 0; z-index: 9997; pointer-events: none; opacity: 0.35; mix-blend-mode: overlay;
}

/* AMBIENT SPOTLIGHT */
#spotlight {
  position: fixed; width: 600px; height: 600px; border-radius: 50%; background: var(--glow);
  pointer-events: none; z-index: 0; transform: translate(-50%, -50%); will-change: left, top;
}

/* SCROLL PROGRESS */
#scroll-progress {
  position: fixed; top: 0; left: 0; width: 0; height: 2px;
  background: linear-gradient(90deg, var(--amber), var(--amber2)); z-index: 9999; transition: width 0.1s linear;
}

/* CURSOR */
#cursor {
  position: fixed; pointer-events: none; z-index: 9999; width: 20px; height: 20px;
  transition: transform 0.15s ease, opacity 0.15s; transform: translate(-50%, -50%);
}
#cursor svg { width: 100%; height: 100%; }
#cursor.hover { transform: translate(-50%, -50%) scale(2); }

/* LOADER */
#loader {
  position: fixed; inset: 0; background: var(--black); z-index: 9998;
  display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 20px;
  transition: opacity 0.8s ease, visibility 0.8s;
}
#loader.hide { opacity: 0; visibility: hidden; }
#loader img { width: 140px; height: auto; opacity: 0; animation: fadeIn 1s ease 0.3s forwards; }
#loader-bar {
  width: 200px; height: 1px; background: var(--border); position: relative; overflow: hidden;
}
#loader-bar::after {
  content: ''; position: absolute; left: -100%; top: 0; width: 100%; height: 100%;
  background: linear-gradient(90deg, transparent, var(--amber), transparent);
  animation: loaderSweep 1.4s ease-in-out forwards;
}
@keyframes loaderSweep { 0% { left: -100%; } 100% { left: 100%; } }
#loader-text {
  font-family: var(--mono); font-size: 11px; color: var(--white3);
  letter-spacing: 0.2em; text-transform: uppercase;
}

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  padding: 0 48px; height: 64px;
  display: flex; align-items: center; justify-content: space-between;
  transition: background 0.3s, border-bottom 0.3s;
  border-bottom: 1px solid transparent;
}
nav.scrolled {
  background: rgba(10,12,16,0.92);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border2);
}
.nav-logo {
  font-family: var(--serif); font-size: 22px; color: var(--white);
  text-decoration: none; letter-spacing: 0.01em;
  display: flex; align-items: center; gap: 10px;
}
.nav-logo img { height: 32px; width: auto; transition: filter 0.4s ease; }
.nav-logo:hover img { filter: brightness(1.2) drop-shadow(0 0 8px rgba(245,166,35,0.3)); }
.nav-links {
  display: flex; align-items: center; gap: 36px; list-style: none;
}
.nav-links a {
  font-family: var(--mono); font-size: 11px; color: var(--white2);
  text-decoration: none; letter-spacing: 0.12em; text-transform: uppercase;
  transition: color 0.2s, letter-spacing 0.2s; position: relative;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 1px;
  background: var(--amber); transition: width 0.3s;
}
.nav-links a:hover { color: var(--white); letter-spacing: 0.16em; }
.nav-links a:hover::after { width: 100%; }
.nav-links a.active { color: var(--amber); }
.nav-links a.active::after { width: 100%; }
.nav-cta {
  font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--black); background: var(--amber); border: none; padding: 10px 20px;
  transition: background 0.2s, transform 0.15s; cursor: none;
}
.nav-cta:hover { background: var(--amber2); transform: translateY(-1px); }
.nav-toggle {
  display: none; flex-direction: column; gap: 5px; background: none; border: none;
  cursor: none; padding: 4px;
}
.nav-toggle span {
  display: block; width: 22px; height: 1.5px; background: var(--white2);
  transition: transform 0.3s, opacity 0.3s;
}
.nav-toggle.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.nav-toggle.open span:nth-child(2) { opacity: 0; }
.nav-toggle.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

/* HERO */
#hero {
  position: relative; height: 100vh; min-height: 700px;
  display: flex; align-items: center; overflow: hidden;
}
#hero-canvas { position: absolute; inset: 0; z-index: 0; }
.hero-grid-overlay {
  position: absolute; inset: 0; z-index: 1;
  background-image:
    linear-gradient(rgba(79,195,247,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(79,195,247,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
}
.hero-content { position: relative; z-index: 3; padding: 0 48px; max-width: 900px; }
.hero-tag {
  font-family: var(--mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--amber); margin-bottom: 28px; display: flex; align-items: center; gap: 12px;
  opacity: 0; animation: fadeUp 0.8s 1.8s forwards;
}
.hero-tag::before { content: ''; width: 32px; height: 1px; background: var(--amber); }
.hero-h1 {
  font-family: var(--serif); font-size: clamp(52px, 7vw, 96px); line-height: 1.0;
  color: var(--white); margin-bottom: 24px; opacity: 0; animation: fadeUp 0.9s 2s forwards;
}
.hero-h1 em {
  font-style: italic;
  background: linear-gradient(135deg, var(--amber), var(--amber2), var(--blue));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.hero-sub {
  font-family: var(--mono); font-size: 13px; color: var(--white2);
  line-height: 1.8; letter-spacing: 0.04em; max-width: 560px; margin-bottom: 40px;
  opacity: 0; animation: fadeUp 0.9s 2.2s forwards;
}
.hero-actions { display: flex; gap: 16px; align-items: center; opacity: 0; animation: fadeUp 0.9s 2.4s forwards; }
.btn-primary {
  font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--black); background: var(--amber); border: none; padding: 14px 28px;
  text-decoration: none; transition: background 0.2s, transform 0.15s; display: inline-block; cursor: none;
}
.btn-primary:hover { background: var(--amber2); transform: translateY(-2px); }
.btn-outline {
  font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--white2); background: transparent; border: 1px solid var(--border);
  padding: 14px 28px; text-decoration: none; transition: border-color 0.2s, color 0.2s, transform 0.15s; display: inline-block; cursor: none;
}
.btn-outline:hover { border-color: var(--white2); color: var(--white); transform: translateY(-2px); }
.hero-scroll-hint {
  position: absolute; bottom: 40px; left: 48px; z-index: 2;
  display: flex; align-items: center; gap: 12px;
  font-family: var(--mono); font-size: 10px; color: var(--white3);
  letter-spacing: 0.15em; text-transform: uppercase;
  opacity: 0; animation: fadeUp 0.8s 2.8s forwards;
}
.scroll-line { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--amber), transparent); animation: scrollPulse 2s ease-in-out infinite; }
@keyframes scrollPulse { 0%,100%{opacity:0.4;transform:scaleY(1)} 50%{opacity:1;transform:scaleY(1.1)} }

.hero-stats-bar {
  position: absolute; bottom: 0; left: 0; right: 0; z-index: 3;
  display: flex; border-top: 1px solid var(--border);
  background: rgba(10,12,16,0.8); backdrop-filter: blur(10px);
  opacity: 0; animation: fadeIn 0.8s 3s forwards;
}
.hero-stat { flex: 1; padding: 20px 32px; border-right: 1px solid var(--border); position: relative; transition: background 0.3s; }
.hero-stat:hover { background: rgba(245,166,35,0.04); }
.hero-stat:last-child { border-right: none; }
.hero-stat-num { font-family: var(--serif); font-size: 32px; color: var(--amber); display: block; line-height: 1; margin-bottom: 6px; }
.hero-stat-label { font-family: var(--mono); font-size: 10px; color: var(--white3); letter-spacing: 0.15em; text-transform: uppercase; }

@keyframes fadeUp { from { opacity:0; transform: translateY(24px); } to { opacity:1; transform: translateY(0); } }
@keyframes fadeIn { from{opacity:0} to{opacity:1} }

/* SECTIONS */
section { padding: 120px 48px; }
.section-tag {
  font-family: var(--mono); font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase;
  color: var(--amber); margin-bottom: 20px; display: flex; align-items: center; gap: 12px;
}
.section-tag::before { content: ''; width: 24px; height: 1px; background: var(--amber); }
.section-h2 {
  font-family: var(--serif); font-size: clamp(36px, 4vw, 60px);
  line-height: 1.05; margin-bottom: 20px; color: var(--white);
}
.section-sub {
  font-family: var(--mono); font-size: 13px; color: var(--white3);
  line-height: 1.8; max-width: 560px; letter-spacing: 0.03em;
}
.reveal { opacity: 0; transform: translateY(32px); transition: opacity 0.7s ease, transform 0.7s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }
.reveal-delay-4 { transition-delay: 0.4s; }
.reveal-delay-5 { transition-delay: 0.5s; }

/* STATS / ABOUT */
#about { background: var(--surface); padding: 120px 48px; }
.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
.about-pillars { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); margin-top: 48px; }
.pillar { background: var(--surface); padding: 32px; position: relative; transition: background 0.3s; }
.pillar:hover { background: var(--surface2); }
.pillar-num { font-family: var(--mono); font-size: 10px; color: var(--amber); letter-spacing: 0.2em; margin-bottom: 16px; }
.pillar-title { font-family: var(--serif); font-size: 20px; margin-bottom: 12px; color: var(--white); }
.pillar-desc { font-size: 13px; color: var(--white3); line-height: 1.7; }
.about-right { padding-top: 60px; }
.metric-row { display: flex; align-items: baseline; gap: 16px; padding: 24px 0; border-bottom: 1px solid var(--border); }
.metric-row:first-child { border-top: 1px solid var(--border); }
.metric-val { font-family: var(--serif); font-size: 52px; color: var(--amber); min-width: 160px; }
.metric-label { font-family: var(--mono); font-size: 12px; color: var(--white2); line-height: 1.6; letter-spacing: 0.05em; }

/* STATS COUNTS */
.stats-counts { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 60px; }
.stat-item { padding: 32px 24px; border: 1px solid var(--border); text-align: center; background: var(--surface); transition: border-color 0.3s, transform 0.3s; }
.stat-item:hover { border-color: var(--border2); transform: translateY(-4px); }
.stat-item .num { font-family: var(--serif); font-size: 42px; color: var(--amber); line-height: 1; }
.stat-item .label { font-family: var(--mono); font-size: 10px; color: var(--white3); letter-spacing: 0.15em; text-transform: uppercase; margin-top: 8px; }

/* SERVICES */
#services { background: var(--surface); }
.services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); margin-top: 60px; }
.service-card { background: var(--surface); padding: 40px 36px; position: relative; overflow: hidden; transition: background 0.3s; }
.service-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--amber); transform: scaleX(0); transform-origin: left; transition: transform 0.4s ease; }
.service-card:hover { background: var(--surface2); }
.service-card:hover::before { transform: scaleX(1); }
.service-icon { width: 40px; height: 40px; border: 1px solid var(--amber); display: flex; align-items: center; justify-content: center; margin-bottom: 24px; font-family: var(--mono); font-size: 14px; color: var(--amber); }
.service-title { font-family: var(--serif); font-size: 22px; margin-bottom: 12px; color: var(--white); }
.service-desc { font-size: 13px; color: var(--white3); line-height: 1.7; margin-bottom: 20px; }
.service-badges { display: flex; flex-wrap: wrap; gap: 6px; }
.tool-badge { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; color: var(--white2); border: 1px solid rgba(255,255,255,0.15); padding: 4px 10px; transition: border-color 0.2s, color 0.2s, background 0.2s; }
.tool-badge:hover { border-color: var(--amber); color: var(--black); background: var(--amber); }

/* BIM */
#digital-eng { background: var(--black); }
.bim-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; margin-top: 60px; }
#bim-canvas-wrap { position: relative; aspect-ratio: 1; background: var(--surface); border: 1px solid var(--border); overflow: hidden; }
#bim-canvas { width: 100%; height: 100%; }
.bim-progress-bar { height: 2px; background: var(--border); margin-top: 16px; position: relative; overflow: hidden; }
.bim-progress-fill { height: 100%; background: var(--amber); transition: width 0.8s ease; box-shadow: 0 0 12px rgba(245,166,35,0.3); }
.bim-stages { margin-top: 24px; }
.bim-stage { display: flex; align-items: center; gap: 16px; padding: 14px 0; border-bottom: 1px solid var(--border); transition: color 0.3s; }
.bim-stage:last-child { border-bottom: none; }
.bim-stage-dot { width: 8px; height: 8px; border: 1px solid var(--white3); transition: background 0.3s, border-color 0.3s; flex-shrink: 0; }
.bim-stage.active .bim-stage-dot { background: var(--amber); border-color: var(--amber); box-shadow: 0 0 12px var(--amber); }
.bim-stage-name { font-family: var(--mono); font-size: 12px; color: var(--white3); letter-spacing: 0.1em; transition: color 0.3s; }
.bim-stage.active .bim-stage-name { color: var(--amber); }
.bim-stage-pct { font-family: var(--mono); font-size: 11px; color: var(--white3); margin-left: auto; }
.bim-counter { font-family: var(--serif); font-size: 72px; color: var(--amber); line-height: 1; margin-bottom: 8px; }
.bim-counter-label { font-family: var(--mono); font-size: 11px; color: var(--white3); letter-spacing: 0.2em; text-transform: uppercase; }

/* INTELLIGENCE */
#intelligence { background: var(--surface); }
.intel-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); margin-top: 60px; }
.intel-card { background: var(--surface); padding: 36px; position: relative; overflow: hidden; }
.intel-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--amber), transparent); opacity: 0; transition: opacity 0.3s; }
.intel-card:hover { background: var(--surface2); }
.intel-card:hover::after { opacity: 1; }
.intel-icon { font-family: var(--mono); font-size: 20px; color: var(--amber); margin-bottom: 20px; opacity: 0.8; }
.intel-title { font-family: var(--serif); font-size: 20px; margin-bottom: 12px; color: var(--white); }
.intel-desc { font-size: 13px; color: var(--white3); line-height: 1.7; margin-bottom: 20px; }
.intel-bullets { list-style: none; font-family: var(--mono); font-size: 11px; color: var(--white3); letter-spacing: 0.06em; }
.intel-bullets li { padding: 4px 0; padding-left: 16px; position: relative; }
.intel-bullets li::before { content: '\25C8'; position: absolute; left: 0; color: var(--amber); font-size: 8px; top: 5px; }

/* DASHBOARD */
#dashboard { background: var(--black); }
.dashboard-layout { display: grid; grid-template-columns: 2fr 1fr; gap: 24px; margin-top: 60px; }
.chart-panel { background: var(--surface); border: 1px solid var(--border); padding: 32px; }
.chart-panel-title { font-family: var(--mono); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--white2); margin-bottom: 8px; display: flex; align-items: center; justify-content: space-between; }
.live-dot { width: 6px; height: 6px; background: var(--amber); border-radius: 50%; animation: livePulse 2s ease-in-out infinite; }
@keyframes livePulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.8)} }
.chart-subtitle { font-family: var(--serif); font-size: 22px; color: var(--white); margin-bottom: 32px; }

.kpi-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); margin-bottom: 32px; }
.kpi-cell { background: var(--surface); padding: 16px; }
.kpi-label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; color: var(--white3); text-transform: uppercase; margin-bottom: 8px; }
.kpi-val { font-family: var(--mono); font-size: 20px; font-weight: 500; }
.kpi-val.good { color: #4ade80; }
.kpi-val.warn { color: var(--amber); }
.kpi-val.bad { color: #f87171; }
.kpi-val.info { color: var(--blue); }
.kpi-sub { font-family: var(--mono); font-size: 10px; color: var(--white3); margin-top: 4px; }
.right-col { display: flex; flex-direction: column; gap: 24px; }
.ev-panel { background: var(--surface); border: 1px solid var(--border); padding: 32px; flex: 1; }

/* DIGITAL TWIN */
#digital-twin { background: var(--surface); position: relative; overflow: hidden; }
.twin-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; margin-top: 60px; }
#twin-canvas-wrap { position: relative; aspect-ratio: 1; background: var(--black); border: 1px solid var(--border); overflow: hidden; }
#twin-canvas { width: 100%; height: 100%; }
.twin-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); margin-top: 32px; }
.twin-metric { background: var(--surface); padding: 20px; }
.twin-metric-label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; color: var(--white3); text-transform: uppercase; margin-bottom: 8px; }
.twin-metric-val { font-family: var(--mono); font-size: 18px; color: var(--blue); font-weight: 500; }
.ai-features { display: flex; flex-direction: column; gap: 24px; margin-top: 24px; }
.ai-feature { display: flex; gap: 20px; align-items: flex-start; padding: 24px; border: 1px solid var(--border); transition: border-color 0.3s, background 0.3s; }
.ai-feature:hover { border-color: var(--amber); background: var(--amber-dim); }
.ai-feature-icon { font-family: var(--mono); font-size: 16px; color: var(--amber); width: 40px; height: 40px; border: 1px solid var(--border2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.ai-feature-title { font-family: var(--serif); font-size: 18px; margin-bottom: 8px; color: var(--white); }
.ai-feature-desc { font-size: 13px; color: var(--white3); line-height: 1.6; }

/* PROJECTS */
#projects { background: var(--black); }
.projects-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); margin-top: 60px; }
.project-card { background: var(--black); padding: 40px; position: relative; overflow: hidden; transition: background 0.3s; }
.project-card:hover { background: var(--surface); }
.project-type { font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; color: var(--amber); text-transform: uppercase; margin-bottom: 16px; }
.project-title { font-family: var(--serif); font-size: 26px; margin-bottom: 8px; color: var(--white); }
.project-location { font-family: var(--mono); font-size: 11px; color: var(--white3); margin-bottom: 8px; letter-spacing: 0.06em; }
.project-client { font-family: var(--mono); font-size: 11px; color: var(--blue); letter-spacing: 0.06em; }
.project-num { position: absolute; bottom: 20px; right: 32px; font-family: var(--serif); font-size: 80px; line-height: 1; color: rgba(255,255,255,0.03); }

/* PARTNERS */
#partners { background: var(--surface); padding: 80px 48px; }
.partners-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1px; background: var(--border); margin-top: 40px; }
.partner-cell { background: var(--surface); padding: 24px; display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 13px; color: var(--white3); letter-spacing: 0.08em; transition: background 0.3s, color 0.3s; }
.partner-cell:hover { background: var(--surface2); color: var(--white); }

/* INSIGHTS */
#insights { background: var(--black); }
.insights-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 60px; }
.insight-card { background: var(--surface); border: 1px solid var(--border); padding: 36px; position: relative; overflow: hidden; transition: transform 0.3s ease, border-color 0.3s; }
.insight-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--amber); transform: scaleY(0); transition: transform 0.4s ease; }
.insight-card:hover { transform: translateY(-8px); border-color: rgba(245,166,35,0.3); }
.insight-card:hover::before { transform: scaleY(1); }
.insight-card:hover .insight-title { color: var(--amber); }
.insight-cat { font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; color: var(--amber); text-transform: uppercase; margin-bottom: 8px; }
.insight-read { font-family: var(--mono); font-size: 10px; color: var(--white3); margin-bottom: 20px; letter-spacing: 0.1em; }
.insight-title { font-family: var(--serif); font-size: 22px; line-height: 1.2; margin-bottom: 16px; color: var(--white); transition: color 0.3s; }
.insight-author { font-family: var(--mono); font-size: 11px; color: var(--white3); letter-spacing: 0.06em; }
.insight-date { font-family: var(--mono); font-size: 11px; color: var(--white3); letter-spacing: 0.06em; }
.insight-arrow { font-family: var(--mono); font-size: 12px; color: var(--amber); letter-spacing: 0.1em; position: absolute; bottom: 36px; left: 36px; transform: translateY(20px); opacity: 0; transition: transform 0.3s, opacity 0.3s; }
.insight-card:hover .insight-arrow { transform: translateY(0); opacity: 1; }

/* CTA */
#cta { background: var(--surface); padding: 120px 48px; text-align: center; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); position: relative; }
#cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 50%, rgba(245,166,35,0.04), transparent 70%); pointer-events: none; }
.cta-h2 { font-family: var(--serif); font-size: clamp(36px, 4vw, 64px); margin-bottom: 20px; color: var(--white); max-width: 800px; margin-left: auto; margin-right: auto; }
.cta-sub { font-family: var(--mono); font-size: 13px; color: var(--white3); margin-bottom: 40px; letter-spacing: 0.04em; }
.cta-actions { display: flex; gap: 16px; justify-content: center; }

/* FOOTER */
footer { background: var(--black); padding: 80px 48px 40px; border-top: 1px solid var(--border); }
.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px; margin-bottom: 60px; }
.footer-brand-name { font-family: var(--serif); font-size: 28px; margin-bottom: 12px; color: var(--white); display: flex; align-items: center; gap: 12px; }
.footer-brand-name img { height: 48px; width: auto; }
.footer-brand-desc { font-size: 13px; color: var(--white3); line-height: 1.7; margin-bottom: 20px; max-width: 300px; }
.footer-col-title { font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--amber); margin-bottom: 20px; }
.footer-links { list-style: none; }
.footer-links li { margin-bottom: 12px; }
.footer-links a { font-family: var(--mono); font-size: 12px; color: var(--white3); text-decoration: none; letter-spacing: 0.06em; transition: color 0.2s; }
.footer-links a:hover { color: var(--white); }
.footer-founders { margin-top: 16px; font-family: var(--mono); font-size: 11px; color: var(--white3); line-height: 1.8; }
.footer-bottom { border-top: 1px solid var(--border); padding-top: 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
.footer-cert { font-family: var(--mono); font-size: 10px; color: var(--white3); letter-spacing: 0.12em; display: flex; gap: 12px; flex-wrap: wrap; }
.footer-cert span { padding: 4px 8px; border: 1px solid var(--border); }
.footer-copy { font-family: var(--mono); font-size: 10px; color: var(--white3); letter-spacing: 0.08em; }
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: var(--black); }
::-webkit-scrollbar-thumb { background: var(--border2); }

@media (max-width: 1024px) {
  .about-grid, .bim-layout, .twin-layout { grid-template-columns: 1fr; gap: 40px; }
  .services-grid, .intel-grid, .projects-grid, .insights-grid { grid-template-columns: 1fr 1fr; }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .kpi-strip { grid-template-columns: repeat(2, 1fr); }
  .partners-grid { grid-template-columns: repeat(3, 1fr); }
  .dashboard-layout { grid-template-columns: 1fr; }
  .stats-counts { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  nav { padding: 0 24px; }
  .nav-toggle { display: flex; }
  .nav-links { position: fixed; top: 64px; left: 0; right: 0; flex-direction: column; background: rgba(10,12,16,0.98); backdrop-filter: blur(20px); padding: 40px 48px; gap: 28px; border-bottom: 1px solid var(--border2); transform: translateY(-120%); transition: transform 0.4s ease; pointer-events: none; }
  .nav-links.open { transform: translateY(0); pointer-events: auto; }
  section { padding: 80px 24px; }
  .hero-content { padding: 0 24px; }
  .hero-stats-bar { flex-direction: column; }
  .hero-stat { border-right: none; border-bottom: 1px solid var(--border); }
  .services-grid, .intel-grid, .projects-grid, .insights-grid { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr; gap: 40px; }
  #hero-canvas { display: none; }
  .kpi-strip { grid-template-columns: 1fr 1fr; }
  .partners-grid { grid-template-columns: repeat(2, 1fr); }
  .stats-counts { grid-template-columns: 1fr 1fr; }
  .about-grid { grid-template-columns: 1fr; }
}
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
}
</style>
