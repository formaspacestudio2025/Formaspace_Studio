// Digital Twin Canvas
(function initTwin() {
  const wrap = document.getElementById('twin-canvas-wrap');
  if (!wrap) return;
  const canvas = document.getElementById('twin-canvas');
  const ctx = canvas.getContext('2d');
  function resize() { canvas.width = wrap.clientWidth; canvas.height = wrap.clientHeight; }
  resize(); window.addEventListener('resize', resize);
  const nodes = [];
  const nodeCount = 40;
  for (let i = 0; i < nodeCount; i++) {
    nodes.push({ x: Math.random(), y: Math.random(), vx: (Math.random() - 0.5) * 0.002, vy: (Math.random() - 0.5) * 0.002, r: Math.random() * 3 + 1, pulse: Math.random() * Math.PI * 2, type: Math.random() > 0.85 ? 'anomaly' : Math.random() > 0.5 ? 'active' : 'idle' });
  }
  let t = 0, sensorAnimated = false;
  const twinObserver = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting && !sensorAnimated) { sensorAnimated = true; animateMetric('sensor-count',0,128,1600,''); animateMetric('stream-count',0,47,1400,''); animateMetric('anomaly-count',0,3,1000,''); animateMetric('accuracy-val',0,94.7,2000,'%',1); } });
  }, { threshold: 0.3 });
  twinObserver.observe(wrap);
  function animateMetric(id,from,to,dur,suffix,decimals=0) {
    const el = document.getElementById(id); if (!el) return;
    const start = performance.now();
    function step(now) { const p = Math.min((now - start) / dur, 1); const ease = 1 - Math.pow(1 - p, 3); const val = from + (to - from) * ease; el.textContent = val.toFixed(decimals) + suffix; if (p < 1) requestAnimationFrame(step); }
    requestAnimationFrame(step);
  }
  function animate() {
    requestAnimationFrame(animate); t += 0.015;
    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0, 0, W, H);
    ctx.strokeStyle = 'rgba(26,31,46,0.8)'; ctx.lineWidth = 0.5;
    for (let x = 0; x < W; x += 40) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke(); }
    for (let y = 0; y < H; y += 40) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke(); }
    ctx.strokeStyle = 'rgba(245,166,35,0.12)'; ctx.lineWidth = 1;
    for (let fl = 0; fl < 6; fl++) { const y = H * 0.7 - fl * H * 0.08; ctx.strokeRect(W * 0.25, y - H * 0.07, W * 0.5, H * 0.07); }
    nodes.forEach(n => { n.x += n.vx + Math.sin(t * 0.5 + n.pulse) * 0.0005; n.y += n.vy + Math.cos(t * 0.3 + n.pulse) * 0.0005; if (n.x < 0 || n.x > 1) n.vx *= -1; if (n.y < 0 || n.y > 1) n.vy *= -1; n.x = Math.max(0, Math.min(1, n.x)); n.y = Math.max(0, Math.min(1, n.y)); });
    for (let i = 0; i < nodes.length; i++) { for (let j = i + 1; j < nodes.length; j++) { const dx = (nodes[i].x - nodes[j].x) * W, dy = (nodes[i].y - nodes[j].y) * H, dist = Math.sqrt(dx * dx + dy * dy); if (dist < 90) { ctx.beginPath(); ctx.moveTo(nodes[i].x * W, nodes[i].y * H); ctx.lineTo(nodes[j].x * W, nodes[j].y * H); ctx.strokeStyle = `rgba(79,195,247,${(1 - dist / 90) * 0.3})`; ctx.lineWidth = 0.5; ctx.stroke(); } } }
    nodes.forEach(n => { const px = n.x * W, py = n.y * H, pulse = Math.sin(t * 2 + n.pulse) * 0.5 + 0.5; let color, glowColor; if (n.type === 'anomaly') { color = '#f87171'; glowColor = 'rgba(248,113,113,'; } else if (n.type === 'active') { color = '#F5A623'; glowColor = 'rgba(245,166,35,'; } else { color = '#4FC3F7'; glowColor = 'rgba(79,195,247,'; } ctx.beginPath(); ctx.arc(px, py, n.r * 3, 0, Math.PI * 2); ctx.fillStyle = glowColor + (pulse * 0.3) + ')'; ctx.fill(); ctx.beginPath(); ctx.arc(px, py, n.r, 0, Math.PI * 2); ctx.fillStyle = color; ctx.fill(); if (n.type === 'anomaly') { ctx.beginPath(); ctx.arc(px, py, n.r * (2 + pulse * 3), 0, Math.PI * 2); ctx.strokeStyle = `rgba(248,113,113,${0.5 - pulse * 0.4})`; ctx.lineWidth = 1; ctx.stroke(); } });
    for (let i = 0; i < 3; i++) { const progress = ((t * 0.4 + i * 0.33) % 1); const n1 = nodes[i * 8], n2 = nodes[i * 8 + 12]; if (n1 && n2) { const px = (n1.x + (n2.x - n1.x) * progress) * W, py = (n1.y + (n2.y - n1.y) * progress) * H; ctx.beginPath(); ctx.arc(px, py, 3, 0, Math.PI * 2); ctx.fillStyle = '#4FC3F7'; ctx.fill(); } }
  }
  animate();
})();

// Automation Canvas
(function initAuto() {
  const wrap = document.querySelector('#automation > div > div:last-child');
  if (!wrap) return;
  const canvas = document.getElementById('auto-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  function resize() { canvas.width = wrap.clientWidth; canvas.height = wrap.clientHeight; }
  resize(); window.addEventListener('resize', resize);
  const layers = [{ nodes: 4, label: 'Site Data' },{ nodes: 6, label: 'AI Layer' },{ nodes: 5, label: 'Analytics' },{ nodes: 3, label: 'Output' }];
  let t = 0;
  const signals = [];
  for (let i = 0; i < 15; i++) { signals.push({ layer: Math.floor(Math.random() * (layers.length - 1)), from: Math.floor(Math.random() * 6), to: Math.floor(Math.random() * 6), progress: Math.random(), speed: 0.004 + Math.random() * 0.006, color: Math.random() > 0.5 ? '#F5A623' : '#4FC3F7' }); }
  function getNodePos(layerIdx, nodeIdx, W, H) { const lCount = layers.length; const x = (layerIdx / (lCount - 1)) * (W * 0.8) + W * 0.1; const nCount = layers[layerIdx].nodes; const y = ((nodeIdx + 1) / (nCount + 1)) * H; return { x, y }; }
  function animate() {
    requestAnimationFrame(animate); t += 0.01;
    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0, 0, W, H);
    for (let li = 0; li < layers.length - 1; li++) { for (let ni = 0; ni < layers[li].nodes; ni++) { for (let nj = 0; nj < layers[li + 1].nodes; nj++) { const p1 = getNodePos(li, ni, W, H), p2 = getNodePos(li + 1, nj, W, H); ctx.beginPath(); ctx.moveTo(p1.x, p1.y); ctx.lineTo(p2.x, p2.y); ctx.strokeStyle = 'rgba(26,32,48,0.8)'; ctx.lineWidth = 0.5; ctx.stroke(); } } }
    signals.forEach(sig => { sig.progress += sig.speed; if (sig.progress > 1) { sig.progress = 0; sig.from = Math.floor(Math.random() * layers[sig.layer].nodes); sig.to = Math.floor(Math.random() * layers[sig.layer + 1].nodes); } const p1 = getNodePos(sig.layer, sig.from % layers[sig.layer].nodes, W, H), p2 = getNodePos(sig.layer + 1, sig.to % layers[sig.layer + 1].nodes, W, H); const sx = p1.x + (p2.x - p1.x) * sig.progress, sy = p1.y + (p2.y - p1.y) * sig.progress; for (let tr = 0; tr < 5; tr++) { const tp = Math.max(0, sig.progress - tr * 0.04), tx = p1.x + (p2.x - p1.x) * tp, ty = p1.y + (p2.y - p1.y) * tp; ctx.beginPath(); ctx.arc(tx, ty, 2 - tr * 0.3, 0, Math.PI * 2); const alpha = (0.8 - tr * 0.15); if (sig.color === '#F5A623') ctx.fillStyle = `rgba(245,166,35,${alpha})`; else ctx.fillStyle = `rgba(79,195,247,${alpha})`; ctx.fill(); } });
    for (let li = 0; li < layers.length; li++) { for (let ni = 0; ni < layers[li].nodes; ni++) { const p = getNodePos(li, ni, W, H); const pulse = Math.sin(t + li + ni) * 0.5 + 0.5; ctx.beginPath(); ctx.arc(p.x, p.y, 4 + pulse * 2, 0, Math.PI * 2); ctx.fillStyle = `rgba(245,166,35,${0.1 + pulse * 0.1})`; ctx.fill(); ctx.beginPath(); ctx.arc(p.x, p.y, 4, 0, Math.PI * 2); ctx.fillStyle = '#F5A623'; ctx.fill(); } const lp = getNodePos(li, -0.5, W, H); ctx.fillStyle = 'rgba(122,120,112,0.8)'; ctx.font = "10px 'IBM Plex Mono'"; ctx.textAlign = 'center'; ctx.fillText(layers[li].label, lp.x, H - 16); }
  }
  animate();
})();

})();
