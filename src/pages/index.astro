<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
(function(){
'use strict';

const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
const isMobile = window.innerWidth < 768;

// Touch detection
if ('ontouchstart' in window) document.body.classList.add('touch');

// Scroll progress
const scrollBar = document.getElementById('scroll-progress');
window.addEventListener('scroll', () => {
  const pct = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
  scrollBar.style.width = (pct * 100) + '%';
}, { passive: true });

// Cursor
const cursor = document.getElementById('cursor');
document.addEventListener('mousemove', e => {
  cursor.style.left = e.clientX + 'px';
  cursor.style.top = e.clientY + 'px';
});
document.querySelectorAll('a,button,.phase-card,.service-card,.intel-card,.project-card,.insight-card,.ai-feature,.bim-stage,.partner-cell').forEach(el => {
  el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
  el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
});

// Spotlight
const spotlight = document.getElementById('spotlight');
document.addEventListener('mousemove', e => {
  spotlight.style.left = e.clientX + 'px';
  spotlight.style.top = e.clientY + 'px';
});

// Loader
window.addEventListener('load', () => {
  setTimeout(() => {
    document.getElementById('loader').classList.add('hide');
    if (!isMobile) initHeroCanvas();
    document.querySelectorAll('.hero-stat-num').forEach(el => {
      if (!el.dataset.animated) animateCounter(el);
    });
  }, 2000);
});

// Nav
const nav = document.getElementById('nav');
const navLinks = document.querySelectorAll('.nav-links a');
const sections = document.querySelectorAll('section[id]');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 60);
  let current = '';
  sections.forEach(sec => {
    const top = sec.offsetTop - 200;
    if (window.scrollY >= top) current = sec.getAttribute('id');
  });
  navLinks.forEach(a => {
    a.style.color = a.getAttribute('href') === '#' + current ? 'var(--amber)' : '';
  });
}, { passive: true });

// Hamburger
const toggle = document.getElementById('navToggle');
const navList = document.querySelector('.nav-links');
if (toggle) {
  toggle.addEventListener('click', () => {
    toggle.classList.toggle('open');
    navList.classList.toggle('open');
  });
  navList.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      toggle.classList.remove('open');
      navList.classList.remove('open');
    });
  });
}

// Intersection Observer - Reveal
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      if (e.target.hasAttribute('data-count')) animateCounter(e.target);
    }
  });
}, { threshold: 0.15 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
document.querySelectorAll('[data-count]').forEach(el => observer.observe(el));

// Counter
function animateCounter(el) {
  if (el.dataset.animated) return;
  el.dataset.animated = 'true';
  const target = parseFloat(el.dataset.count);
  const prefix = el.dataset.prefix || '';
  const suffix = el.dataset.suffix || '';
  const duration = 1800;
  const start = performance.now();
  const isDecimal = target % 1 !== 0;
  function step(now) {
    const p = Math.min((now - start) / duration, 1);
    const ease = 1 - Math.pow(1 - p, 4);
    const val = target * ease;
    el.textContent = prefix + (isDecimal ? val.toFixed(1) : Math.floor(val)) + suffix;
    if (p < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

// Hero Three.js
function initHeroCanvas() {
  if (window.innerWidth < 768) return;
  const canvas = document.getElementById('hero-canvas');
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
  camera.position.set(0, 6, 18);
  camera.lookAt(0, 0, 0);
  const floors = [];
  const floorCount = 8;
  for (let i = 0; i < floorCount; i++) {
    const geo = new THREE.BoxGeometry(6, 0.3, 6);
    const wireMat = new THREE.MeshBasicMaterial({ color: 0xF5A623, wireframe: true, transparent: true, opacity: 0 });
    const solidMat = new THREE.MeshBasicMaterial({ color: 0x1a1f2e, transparent: true, opacity: 0, wireframe: false });
    const wire = new THREE.Mesh(geo, wireMat);
    const solid = new THREE.Mesh(geo, solidMat);
    wire.position.y = i * 1.2 - 4;
    solid.position.y = i * 1.2 - 4;
    scene.add(wire);
    scene.add(solid);
    floors.push({ wire, solid, wireMat, solidMat, delay: i * 0.3 });
  }
  const colPositions = [[-3, 0, -3], [3, 0, -3], [-3, 0, 3], [3, 0, 3]];
  colPositions.forEach(pos => {
    const geo = new THREE.BoxGeometry(0.15, floorCount * 1.2, 0.15);
    const mat = new THREE.MeshBasicMaterial({ color: 0xF5A623, wireframe: true, transparent: true, opacity: 0.15 });
    const col = new THREE.Mesh(geo, mat);
    col.position.set(pos[0], (floorCount * 1.2) / 2 - 4.6, pos[2]);
    scene.add(col);
  });
  const particleCount = 200;
  const positions = new Float32Array(particleCount * 3);
  for (let i = 0; i < particleCount; i++) {
    positions[i * 3]     = (Math.random() - 0.5) * 30;
    positions[i * 3 + 1] = (Math.random() - 0.5) * 20;
    positions[i * 3 + 2] = (Math.random() - 0.5) * 30;
  }
  const partGeo = new THREE.BufferGeometry();
  partGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
  const partMat = new THREE.PointsMaterial({ color: 0x4FC3F7, size: 0.08, transparent: true, opacity: 0.6 });
  const particles = new THREE.Points(partGeo, partMat);
  scene.add(particles);
  const gridHelper = new THREE.GridHelper(30, 30, 0x1a2030, 0x111318);
  gridHelper.position.y = -4.6;
  scene.add(gridHelper);
  let elapsed = 0;
  let scrollY = 0;
  window.addEventListener('scroll', () => { scrollY = window.scrollY; }, { passive: true });
  function animate() {
    requestAnimationFrame(animate);
    elapsed += 0.01;
    floors.forEach(({ wire, solid, wireMat, solidMat, delay }) => {
      const t = Math.max(0, Math.min(1, (elapsed - delay) * 0.8));
      wireMat.opacity = t * 0.8;
      wire.scale.y = 0.1 + t * 0.9;
      const scrollFactor = Math.min(1, scrollY / 500);
      solidMat.opacity = scrollFactor * 0.4 * t;
      wireMat.opacity = (1 - scrollFactor * 0.6) * t * 0.8;
    });
    scene.rotation.y = elapsed * 0.12;
    particles.rotation.y = elapsed * 0.03;
    const pos = partGeo.attributes.position.array;
    for (let i = 0; i < particleCount; i++) { pos[i * 3 + 1] += Math.sin(elapsed + i) * 0.003; }
    partGeo.attributes.position.needsUpdate = true;
    renderer.render(scene, camera);
  }
  animate();
  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });
}

// BIM Canvas
(function initBIM() {
  const wrap = document.getElementById('bim-canvas-wrap');
  const canvas = document.getElementById('bim-canvas');
  if (!wrap || !canvas) return;
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  function resize() {
    const w = wrap.clientWidth; const h = wrap.clientHeight;
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    camera.aspect = w / h; camera.updateProjectionMatrix();
  }
  const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 100);
  camera.position.set(8, 6, 10);
  camera.lookAt(0, 1, 0);
  const scene = new THREE.Scene();
  const stages = [];
  const s0 = new THREE.Group();
  for (let fl = 0; fl < 5; fl++) {
    const cols = [[-2,0,-2],[2,0,-2],[-2,0,2],[2,0,2]];
    cols.forEach(p => {
      const g = new THREE.BoxGeometry(0.2, 1.0, 0.2);
      const m = new THREE.MeshBasicMaterial({ color: 0xF5A623, wireframe: true });
      const c = new THREE.Mesh(g, m);
      c.position.set(p[0], fl * 1.2, p[2]);
      s0.add(c);
    });
    const fg = new THREE.BoxGeometry(4.2, 0.12, 4.2);
    const fm = new THREE.MeshBasicMaterial({ color: 0xF5A623, wireframe: true });
    const f = new THREE.Mesh(fg, fm);
    f.position.y = fl * 1.2;
    s0.add(f);
  }
  stages.push(s0); scene.add(s0);
  const s1 = new THREE.Group(); s1.visible = false;
  const facadePositions = [
    { pos: [0, 2.4, -2.2], rot: [0, 0, 0], size: [4.4, 5.0, 0.08] },
    { pos: [0, 2.4, 2.2],  rot: [0, 0, 0], size: [4.4, 5.0, 0.08] },
    { pos: [-2.2, 2.4, 0], rot: [0, Math.PI/2, 0], size: [4.4, 5.0, 0.08] },
    { pos: [2.2, 2.4, 0],  rot: [0, Math.PI/2, 0], size: [4.4, 5.0, 0.08] },
  ];
  facadePositions.forEach(fd => {
    const g = new THREE.BoxGeometry(...fd.size);
    const m = new THREE.MeshBasicMaterial({ color: 0x4FC3F7, wireframe: true, transparent: true, opacity: 0.5 });
    const mesh = new THREE.Mesh(g, m);
    mesh.position.set(...fd.pos);
    mesh.rotation.set(...fd.rot);
    s1.add(mesh);
  });
  stages.push(s1); scene.add(s1);
  const s2 = new THREE.Group(); s2.visible = false;
  const mepColors = [0xff6b6b, 0x4FC3F7, 0xffd93d, 0x6bcb77];
  for (let i = 0; i < 4; i++) {
    const pts = [];
    for (let j = 0; j < 6; j++) pts.push(new THREE.Vector3(-1.5 + i * 0.6, j * 0.9 + 0.3, (Math.random() - 0.5) * 2));
    const curve = new THREE.CatmullRomCurve3(pts);
    const tubeGeo = new THREE.TubeGeometry(curve, 20, 0.06, 6, false);
    const mat = new THREE.MeshBasicMaterial({ color: mepColors[i], wireframe: true });
    s2.add(new THREE.Mesh(tubeGeo, mat));
  }
  stages.push(s2); scene.add(s2);
  const s3 = new THREE.Group(); s3.visible = false;
  for (let fl = 0; fl < 5; fl++) {
    const g = new THREE.BoxGeometry(3.8, 0.05, 3.8);
    const m = new THREE.MeshBasicMaterial({ color: 0xffffff, wireframe: true, transparent: true, opacity: 0.3 });
    const f = new THREE.Mesh(g, m);
    f.position.y = fl * 1.2 + 0.1;
    s3.add(f);
  }
  stages.push(s3); scene.add(s3);
  const s4 = new THREE.Group(); s4.visible = false;
  for (let fl = 0; fl < 5; fl++) {
    const g = new THREE.BoxGeometry(4.4, 1.1, 4.4);
    const m = new THREE.MeshBasicMaterial({ color: 0x4FC3F7, wireframe: true, transparent: true, opacity: 0.2 });
    const f = new THREE.Mesh(g, m);
    f.position.y = fl * 1.2 + 0.4;
    s4.add(f);
  }
  stages.push(s4); scene.add(s4);
  const grid = new THREE.GridHelper(12, 12, 0x1a2030, 0x111318);
  grid.position.y = -0.1;
  scene.add(grid);
  let currentStage = 0;
  const stageEls = document.querySelectorAll('.bim-stage');
  const pctEl = document.getElementById('bim-pct');
  const progressEl = document.getElementById('bim-progress');
  const pcts = [20, 40, 60, 80, 100];
  function goToStage(s) {
    stages.forEach((g, i) => { g.visible = i <= s; });
    stageEls.forEach((el, i) => el.classList.toggle('active', i === s));
    pctEl.textContent = pcts[s];
    progressEl.style.width = pcts[s] + '%';
    currentStage = s;
    resetStageTimer();
  }
  stageEls.forEach((el, i) => el.addEventListener('click', () => goToStage(i)));
  let stageTimer;
  function resetStageTimer() {
    clearInterval(stageTimer);
    stageTimer = setInterval(() => { goToStage((currentStage + 1) % 5); }, 4000);
  }
  resetStageTimer();
  let t = 0;
  function animate() {
    requestAnimationFrame(animate);
    t += 0.008;
    scene.rotation.y = t * 0.3;
    renderer.render(scene, camera);
  }
  resize();
  window.addEventListener('resize', resize);
  animate();
})();

// S-Curve
(function initSCurve() {
  const svg = document.getElementById('scurve-svg');
  if (!svg) return;
  const W = 680, H = 320;
  const pad = { left: 50, right: 20, top: 40, bottom: 40 };
  const cW = W - pad.left - pad.right;
  const cH = H - pad.top - pad.bottom;
  const months = 24;
  const planned = Array.from({ length: months }, (_, i) => {
    const t = i / (months - 1);
    return 1 / (1 + Math.exp(-10 * (t - 0.5)));
  });
  const actual = planned.map((v, i) => {
    if (i < 8) return v * (0.88 + i * 0.008);
    if (i < 18) return v * (0.94 + (i - 8) * 0.003);
    return v * 0.99;
  });
  const gridG = document.getElementById('grid-lines');
  for (let g = 0; g <= 5; g++) {
    const y = pad.top + (cH / 5) * g;
    const line = document.createElementNS('http://www.w3.org/2000/svg','line');
    line.setAttribute('x1', pad.left); line.setAttribute('x2', pad.left + cW); line.setAttribute('y1', y); line.setAttribute('y2', y); line.setAttribute('stroke','#1a1f2e'); line.setAttribute('stroke-width','1');
    gridG.appendChild(line);
    const label = document.createElementNS('http://www.w3.org/2000/svg','text');
    label.setAttribute('x', pad.left - 8); label.setAttribute('y', y + 4); label.setAttribute('text-anchor','end');
    label.setAttribute('font-family',"'IBM Plex Mono',monospace"); label.setAttribute('font-size','10'); label.setAttribute('fill','#7a7870');
    label.textContent = (100 - g * 20) + '%';
    gridG.appendChild(label);
  }
  const axisG = document.getElementById('axis-labels');
  [1, 6, 12, 18, 24].forEach(m => {
    const x = pad.left + ((m - 1) / (months - 1)) * cW;
    const label = document.createElementNS('http://www.w3.org/2000/svg','text');
    label.setAttribute('x', x); label.setAttribute('y', pad.top + cH + 16); label.setAttribute('text-anchor','middle');
    label.setAttribute('font-family',"'IBM Plex Mono',monospace"); label.setAttribute('font-size','10'); label.setAttribute('fill','#7a7870');
    label.textContent = 'M' + m;
    axisG.appendChild(label);
  });
  function buildPathD(data) {
    return data.map((v, i) => {
      const x = pad.left + (i / (months - 1)) * cW;
      const y = pad.top + cH - v * cH;
      return (i === 0 ? 'M' : 'L') + x.toFixed(1) + ',' + y.toFixed(1);
    }).join(' ');
  }
  const plannedPath = document.getElementById('planned-path');
  const actualPath = document.getElementById('actual-path');
  plannedPath.setAttribute('d', buildPathD(planned));
  actualPath.setAttribute('d', buildPathD(actual));
  function getLength(el) { try { return el.getTotalLength(); } catch(e) { return 1000; } }
  const dashObserver = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        [plannedPath, actualPath].forEach(path => {
          const len = getLength(path);
          path.style.strokeDasharray = len;
          path.style.strokeDashoffset = len;
          path.style.transition = 'stroke-dashoffset 2.5s cubic-bezier(0.4,0,0.2,1)';
          setTimeout(() => { path.style.strokeDashoffset = 0; }, 100);
        });
        dashObserver.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  dashObserver.observe(svg);
})();

// EV Bar Chart
(function initEV() {
  const svg = document.getElementById('ev-svg');
  if (!svg) return;
  const W = 300, H = 240;
  const pad = { left: 30, right: 10, top: 30, bottom: 30 };
  const cH = H - pad.top - pad.bottom;
  const labels = ['M1','M2','M3','M4','M5','M6'];
  const bcws = [0.15, 0.28, 0.45, 0.60, 0.74, 0.88];
  const bcwp = [0.12, 0.23, 0.40, 0.54, 0.68, 0.82];
  const acwp = [0.13, 0.26, 0.44, 0.59, 0.75, 0.90];
  const groupW = (W - pad.left - pad.right) / 6;
  const barW = groupW * 0.25;
  [['#F5A623', 'BCWS'], ['#4FC3F7', 'BCWP'], ['rgba(255,255,255,0.25)', 'ACWP']].forEach((item, i) => {
    const g = document.createElementNS('http://www.w3.org/2000/svg','g');
    const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');
    rect.setAttribute('x', 20 + i * 75); rect.setAttribute('y', 8); rect.setAttribute('width', 10); rect.setAttribute('height', 6); rect.setAttribute('fill', item[0]);
    g.appendChild(rect);
    const text = document.createElementNS('http://www.w3.org/2000/svg','text');
    text.setAttribute('x', 34 + i * 75); text.setAttribute('y', 15);
    text.setAttribute('font-family',"'IBM Plex Mono',monospace"); text.setAttribute('font-size','9'); text.setAttribute('fill','#7a7870');
    text.textContent = item[1];
    g.appendChild(text);
    svg.appendChild(g);
  });
  labels.forEach((label, gi) => {
    const gx = pad.left + gi * groupW + groupW / 2;
    const sets = [bcws[gi], bcwp[gi], acwp[gi]];
    const colors = ['#F5A623', '#4FC3F7', 'rgba(255,255,255,0.2)'];
    sets.forEach((val, bi) => {
      const bH = val * cH;
      const x = gx + (bi - 1) * (barW + 2) - barW / 2;
      const y = pad.top + cH - bH;
      const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');
      rect.setAttribute('x', x); rect.setAttribute('y', pad.top + cH); rect.setAttribute('width', barW); rect.setAttribute('height', 0); rect.setAttribute('fill', colors[bi]);
      svg.appendChild(rect);
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            setTimeout(() => { rect.style.transition = 'y 0.8s ease, height 0.8s ease'; rect.setAttribute('y', y); rect.setAttribute('height', bH); }, bi * 100 + gi * 60);
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.3 });
      obs.observe(svg);
    });
    const variance = ((bcwp[gi] / bcws[gi] - 1) * 100).toFixed(0);
    const text = document.createElementNS('http://www.w3.org/2000/svg','text');
    text.setAttribute('x', gx); text.setAttribute('y', pad.top + cH - bcws[gi] * cH - 5); text.setAttribute('text-anchor','middle');
    text.setAttribute('font-family',"'IBM Plex Mono',monospace"); text.setAttribute('font-size','9'); text.setAttribute('fill', variance < 0 ? '#f87171' : '#4ade80');
    text.textContent = variance + '%';
    svg.appendChild(text);
    const ml = document.createElementNS('http://www.w3.org/2000/svg','text');
    ml.setAttribute('x', gx); ml.setAttribute('y', pad.top + cH + 16); ml.setAttribute('text-anchor','middle');
    ml.setAttribute('font-family',"'IBM Plex Mono',monospace"); ml.setAttribute('font-size','9'); ml.setAttribute('fill','#7a7870'); ml.textContent = label;
    svg.appendChild(ml);
  });
})();

